# Copy this file to .env and replace every REPLACE_ME value before starting.
CORDIS_POSTGRES_PASSWORD=REPLACE_ME
CORDIS_DATABASE_DSN=postgres://cordis:REPLACE_ME@postgres:5432/cordis?sslmode=disable

CORDIS_ACCESS_TOKEN_SECRET=REPLACE_ME_WITH_RANDOM_ACCESS_TOKEN_SECRET
CORDIS_REFRESH_TOKEN_SECRET=REPLACE_ME_WITH_RANDOM_REFRESH_TOKEN_SECRET
CORDIS_TOTP_ENCRYPTION_KEY=REPLACE_ME_WITH_BASE64_ENCODED_32_BYTE_KEY

CORDIS_MINIO_ROOT_USER=REPLACE_ME
CORDIS_MINIO_ROOT_PASSWORD=REPLACE_ME_WITH_AT_LEAST_8_CHARACTERS
CORDIS_BROWSER_ORIGINS=http://localhost:5173,http://localhost:4173
CORDIS_GATEWAY_ORIGIN=http://localhost:5173

CORDIS_API_PORT=8080
CORDIS_GATEWAY_PORT=8081
CORDIS_KAFKA_PORT=9092
CORDIS_MINIO_PORT=9000
CORDIS_MINIO_CONSOLE_PORT=9001
